AGENT_RUNTIME_HOST=127.0.0.1
AGENT_RUNTIME_PORT=8000
AGENT_RUNTIME_DB_URL=sqlite+aiosqlite:///./runtime.db
# Point to a concrete sentence-transformers model directory on the current Windows machine.
# Replace this path for a fresh environment or later containerized setup.
AGENT_RUNTIME_EMBEDDING_MODEL_ROOT=C:\models\embedding_models\iic\nlp_gte_sentence-embedding_chinese-base
# DeepSeek-compatible default LLM settings used by the local startup scripts.
AGENT_RUNTIME_MODEL_BASE_URL=https://api.deepseek.com
AGENT_RUNTIME_MODEL_API_KEY=
AGENT_RUNTIME_MODEL_NAME=deepseek-v4-flash
AGENT_RUNTIME_MODEL_TIMEOUT_SECONDS=60

# Docker Compose host-side settings.
HOST_PUBLISHED_PORT=8000
# Used by docker-compose.yml for the read-only bind mount into /models/embedding_models.
# This should be the host-side directory that contains the concrete model folder above.
HOST_EMBEDDING_MODEL_ROOT=C:\models\embedding_models

# Docker Compose container-side settings.
CONTAINER_AGENT_RUNTIME_HOST=0.0.0.0
CONTAINER_AGENT_RUNTIME_PORT=8000
CONTAINER_AGENT_RUNTIME_DB_URL=sqlite+aiosqlite:////data/runtime.db
CONTAINER_AGENT_RUNTIME_EMBEDDING_MODEL_ROOT=/models/embedding_models

PYTHONPATH=src
